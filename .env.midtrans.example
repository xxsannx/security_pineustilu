# Midtrans Payment Gateway Configuration
# Copy dan update dengan kredensial Midtrans Anda

# Midtrans Server Key (JANGAN SHARE, gunakan untuk backend only)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxxxxxx

# Midtrans Client Key (bisa di-expose ke frontend)
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxxxxxx

# Sandbox vs Production mode
# false = Sandbox (untuk testing)
# true = Production (live)
MIDTRANS_IS_PRODUCTION=false

# Contoh Sandbox Keys untuk Testing:
# MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxx
# MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxx

# Cara mendapatkan keys:
# 1. Buat account di https://midtrans.com
# 2. Login ke https://dashboard.midtrans.com
# 3. Settings > Access Keys
# 4. Copy Server Key dan Client Key (dari Sandbox tab)

# Production Keys hanya didapat setelah approved untuk production
# Setup untuk production: https://docs.midtrans.com/docs/switching-to-production-mode
